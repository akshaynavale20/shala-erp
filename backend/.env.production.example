# Production environment variables — NEVER commit actual values
NODE_ENV=production
PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sms_user
DB_PASSWORD=<CHANGE: strong random password>
DB_DATABASE=sms_db
DB_SYNCHRONIZE=false

# Generate with: openssl rand -base64 64
JWT_SECRET=<CHANGE: openssl rand -base64 64>
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=<CHANGE: openssl rand -base64 64>
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=https://your-domain.com

SMS_GATEWAY=msg91
SMS_API_KEY=<get from MSG91 dashboard>
SMS_SENDER_ID=<DLT-registered 6-char sender ID>
SMS_CRON_ENABLED=true

REDIS_HOST=localhost
REDIS_PORT=6379
